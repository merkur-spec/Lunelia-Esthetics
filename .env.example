# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Server
PORT=3000
NODE_ENV=development
DOMAIN=http://localhost:3000
CORS_ORIGIN=
CLIENT_TOKEN_SECRET=replace-with-a-random-64-character-secret
ADMIN_TOKEN_SECRET=replace-with-a-different-random-64-character-secret

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/lunelia
DB_SSL=false

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin (Basic Auth)
ADMIN_USER=admin
ADMIN_PASS_HASH=replace-with-scrypt-hash
# Optional legacy fallback for local development only
# ADMIN_PASS=change-this-password
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX=100

